// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum MatchStatus {
  SCHEDULED
  PLAYED
  CANCELED
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
}


enum TransferType {
  PURCHASE
  SALE
  LOAN
  FREE_AGENT_SIGNING
  RELEASE
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)

  teams        Team[]   @relation("TeamOwner")

  requestedTransfers Transfer[] @relation("RequestedTransfers")
  approvedTransfers  Transfer[] @relation("ApprovedTransfers")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model League {
  id        String         @id @default(uuid())
  name      String         @unique
  slug      String         @unique
  isActive  Boolean        @default(true)

  teams     Team[]
  matches   Match[]
  standings TeamStanding[]

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Team {
  id          String         @id @default(uuid())
  name        String
  slug        String
  budget      Decimal        @db.Decimal(12, 2)
  debtLimit  Decimal  @default(0)
  isAvailable Boolean        @default(true)

  avatarUrl   String?

  leagueId    String
  league      League         @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  ownerId     String?
  owner       User?          @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  homeMatches Match[]        @relation("HomeTeam")
  awayMatches Match[]        @relation("AwayTeam")
  players Player[]
  events MatchEvent[]

  standing    TeamStanding?

  incomingTransfers Transfer[] @relation("TransferToTeam")
  outgoingTransfers Transfer[] @relation("TransferFromTeam")

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([name, leagueId])
  @@unique([slug, leagueId])
  @@index([leagueId])
  @@index([ownerId])
}

model Match {
  id          String      @id @default(uuid())

  leagueId    String
  league      League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  homeTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)

  awayTeamId  String
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  events MatchEvent[]

  homeGoals   Int?
  awayGoals   Int?

  playedAt    DateTime?
  status      MatchStatus @default(SCHEDULED)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([leagueId, status])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([playedAt])
}

model TeamStanding {
  id            String   @id @default(uuid())

  leagueId       String
  league         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  teamId         String   @unique
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  played         Int      @default(0)
  won            Int      @default(0)
  drawn          Int      @default(0)
  lost           Int      @default(0)
  goalsFor       Int      @default(0)
  goalsAgainst   Int      @default(0)
  goalDifference Int      @default(0)
  points         Int      @default(0)

  updatedAt      DateTime @updatedAt

  @@unique([leagueId, teamId])
  @@index([leagueId, points, goalDifference])
}

model Player {
  id        String   @id @default(uuid())
  name      String
  number    Int?
  position  String?
  isActive  Boolean  @default(true)

  teamId    String?
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  events    MatchEvent[]
  transfers  Transfer[]

  currentClubName  String?
  currentLeagueName  String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
}

model MatchEvent {
  id        String         @id @default(uuid())

  matchId    String
  match      Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId   String
  player     Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  teamId     String
  team       Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  type       MatchEventType
  minute     Int

  createdAt  DateTime       @default(now())

  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@index([type])
}


model Transfer {
  id                  String   @id @default(uuid())

  playerId            String
  player              Player   @relation(fields: [playerId], references: [id])

  fromTeamId          String?
  fromTeam            Team?    @relation("TransferFromTeam", fields: [fromTeamId], references: [id])

  fromExternalName    String?
  fromExternalLeague  String?

  toTeamId            String
  toTeam              Team     @relation("TransferToTeam", fields: [toTeamId], references: [id])

  requestedById       String
  requestedBy         User     @relation("RequestedTransfers", fields: [requestedById], references: [id])

  approvedById        String?
  approvedBy          User?    @relation("ApprovedTransfers", fields: [approvedById], references: [id])

  amount              Decimal
  status              TransferStatus
  type                TransferType

  notes               String?
  createdAt           DateTime @default(now())
  approvedAt          DateTime?
  completedAt         DateTime?
  rejectedAt          DateTime?
}